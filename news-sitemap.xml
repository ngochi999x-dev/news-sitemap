const fs = require('fs');
const { SitemapStream } = require('sitemap');
const { Readable } = require('stream');

// Array of your news articles
const articles = [
    { url: 'https://example.com/article1', lastModified: '2026-03-31' },
    { url: 'https://example.com/article2', lastModified: '2026-03-30' },
];

// Create a stream to write to
const stream = new SitemapStream({ hostname: 'https://example.com/' });

// Create a readable stream and push articles to the sitemap
const readable = new Readable();
readable._read = () => {};

// Adding articles to the sitemap stream
articles.forEach(article => {
    stream.write({
        url: article.url,
        lastmod: article.lastModified,
        changefreq: 'daily',
        priority: 0.8,
    });
});

// Close the sitemap stream
stream.end();

// Write the sitemap to file
stream.toString();
